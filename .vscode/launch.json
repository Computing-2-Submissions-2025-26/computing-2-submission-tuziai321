{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Open Realmline in Browser",
            "type": "msedge",
            "request": "launch",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}/web-app",
            "userDataDir": "${workspaceFolder}/.vscode/edge-debug-profile",
            "runtimeArgs": [
                "--new-window"
            ],
            "preLaunchTask": "start Realmline server",
            "skipFiles": [
                "${workspaceFolder}/node_modules/**",
                "<node_internals>/**"
            ]
        },
        {
            "name": "Debug Module",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/web-app/Module.js",
            "skipFiles": [
                "${workspaceFolder}/node_modules/**",
                "<node_internals>/**"
            ]
        },
        {
            "name": "Generate Docs",
            "command": "npm run docs",
            "request": "launch",
            "type": "node-terminal"
        }
    ]
}
